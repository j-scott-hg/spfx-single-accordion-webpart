{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx/client-side-web-part-manifest.schema.json",
  "id": "17361e33-c9f0-4a41-b1cf-e1ec8ed15ba7",
  "alias": "CustomAccordionWebPart",
  "componentType": "WebPart",

  "version": "*",
  "manifestVersion": 2,

  "requiresCustomScript": false,
  "supportedHosts": ["SharePointWebPart", "TeamsPersonalApp", "TeamsTab", "SharePointFullPage"],
  "supportsThemeVariants": true,

  "preconfiguredEntries": [{
    "groupId": "cf066440-0614-43d6-98ae-0b31cf14c7c3",
    "group": { "default": "Text, media, and content" },
    "title": { "default": "Single Accordion" },
    "description": { "default": "A single expandable/collapsible accordion section for disclaimers, policies, and supplementary content." },
    "officeFabricIconFontName": "GroupedList",
    "properties": {
      "webPartTitle": "Single Accordion",
      "showTitle": false,
      "titleFontSize": "16",
      "titleFontWeight": "600",
      "titleColor": "",
      "titleAlignment": "left",
      "titleSpacingBelow": "12",

      "triggerText": "Full disclaimer here",
      "defaultExpanded": false,
      "bodyContent": "<p>Enter your full disclaimer, policy text, or supplementary content here.</p>",

      "widthMode": "full",
      "maxWidth": "800",
      "widthUnit": "px",
      "containerAlignment": "left",

      "triggerFontFamily": "",
      "triggerFontSize": "15",
      "triggerFontWeight": "600",
      "triggerTextColor": "#323130",
      "triggerBgColor": "#f3f2f1",
      "triggerBgColorOpen": "",
      "triggerBorderColor": "#edebe9",
      "triggerBorderColorOpen": "",
      "triggerBorderRadius": "4",
      "triggerPaddingV": "12",
      "triggerPaddingH": "16",
      "triggerMinHeight": "48",
      "triggerAlignment": "left",
      "triggerWrapText": true,
      "clickAreaFull": true,

      "bodyFontFamily": "",
      "bodyFontSize": "14",
      "bodyFontWeight": "400",
      "bodyLineHeight": "1.6",
      "bodyTextColor": "#323130",
      "bodyBgColor": "#ffffff",
      "bodyPaddingV": "16",
      "bodyPaddingH": "16",
      "bodyBorderColor": "#edebe9",
      "bodyBorderWidth": "1",
      "bodyBorderRadius": "0",
      "bodyTextAlignment": "left",
      "bodyTopSpacing": "0",

      "showIcon": true,
      "iconType": "chevron",
      "iconPlacement": "right",
      "iconSize": "16",
      "iconColor": "",
      "animateIcon": true,

      "showDivider": true,
      "boxShadow": false,
      "marginTop": "0",
      "marginBottom": "0",
      "containerPaddingV": "0",
      "containerPaddingH": "0",
      "transitionDuration": "250",
      "compactMode": false
    }
  }]
